timetable_*.pdf
timetable_*.html

# macOSが勝手に作るファイル(外付けSSD上の「._〜」も含む)
.DS_Store
._*

# Pythonのキャッシュ
__pycache__/
*.pyc

# Claude Codeのローカル設定
.claude/

# ダウンロードしたGTFSデータ(スクリプトで再取得できる)
gtfs_*/

# 交通空白マップのダウンロードデータ・生成物(docs/plan_gap_map.md 参照)
# ルートの data/ だけを無視する(webapp/data/ のJSONはPages配信に必要なのでコミットする)
/data/*
/output/
# 例外: 人間が編集するマスタ類はコミットして残す
!/data/districts_master.csv
!/data/subdistricts_master.csv
!/data/operators_master.csv
!/data/demand_phone_master.csv
!/data/region.json

# 生成物(スクリプトで再生成できる)
timetable_*.pdf
timetable_*.html

# macOSが勝手に作るファイル(外付けSSD上の「._〜」も含む)
.DS_Store
._*

# Pythonのキャッシュ
__pycache__/
*.pyc

# Claude Codeのローカル設定
.claude/
